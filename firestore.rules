rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isCoachOfUser(userId) {
      return isSignedIn()
             && exists(/databases/$(database)/documents/users/$(userId))
             && get(/databases/$(database)/documents/users/$(userId)).data.coachId == request.auth.uid;
    }

    // Public profile surface for cross-user features (nickname/avatar only).
    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Lightweight user directory for coach/admin pilot lists.
    // It intentionally excludes heavy runtime projections such as stats/sessionIndex.
    match /pilotDirectory/{userId} {
      allow read: if isOwner(userId)
                  || isAdmin()
                  || (isSignedIn() && resource.data.coachId == request.auth.uid);
      allow write: if isOwner(userId) || isAdmin();
    }

    // Users collection (private profile + runtime state)
    match /users/{userId} {
      // Owner can read/write own profile.
      allow read, write: if isOwner(userId);

      // Coach can read assigned pilots only.
      allow read: if isCoachOfUser(userId);

      // Admin can read everything in users.
      allow read: if isAdmin();

      // === Sessions subcollection ===
      match /sessions/{sessionId} {
        allow read: if isAdmin();

        // Public session sharing between authenticated users.
        allow read: if isSignedIn() && resource.data.isPublic == true;

        // Owner full access.
        allow read, write: if isOwner(userId);

        // Coach can read assigned pilot sessions.
        allow read: if isCoachOfUser(userId);

        match /rawChunks/{chunkId} {
          allow read: if isAdmin();

          // Public chunk access mirrors session sharing (denormalized field).
          allow read: if isSignedIn() && resource.data.isPublic == true;

          // Owner full access.
          allow read, write: if isOwner(userId);

          // Coach can read assigned pilot chunks.
          allow read: if isCoachOfUser(userId);
        }
      }

      match /uploads/{uploadId} {
        allow read, write: if isOwner(userId);
        allow read: if isAdmin();
      }

      match /trackBests/{trackId} {
        allow read: if isAdmin();
        allow read, write: if isOwner(userId);
        allow read: if isCoachOfUser(userId);
      }

      match /trackDetailProjections/{trackId} {
        allow read: if isAdmin();
        allow read, write: if isOwner(userId);
        allow read: if isCoachOfUser(userId);
      }

      match /activities/{activityId} {
        allow read: if isAdmin();
        allow read, write: if isOwner(userId);
        allow read: if isCoachOfUser(userId);
      }
    }
  }
}
