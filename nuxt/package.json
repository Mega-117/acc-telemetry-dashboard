{
  "name": "nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "build:docs": "powershell -ExecutionPolicy Bypass -Command \"$env:ACC_NUXT_PUBLIC_DIR='../docs'; npm run build\"",
    "dev": "nuxt dev --host localhost",
    "generate": "powershell -ExecutionPolicy Bypass -Command \"$env:ACC_NUXT_PUBLIC_DIR='../docs'; nuxt generate\"",
    "preview": "nuxt preview",
    "voice:kokoro": "python scripts/kokoro_tts_server.py",
    "postinstall": "nuxt prepare",
    "check:parity": "node scripts/check_projection_parity.mjs",
    "check:firebase-tracking": "node scripts/check_firebase_tracking.mjs",
    "check:sync-runtime": "node scripts/check_sync_runtime.mjs",
    "check:sync-trackbests-aggregate": "node scripts/check_sync_trackbests_aggregate.mjs",
    "check:pilots-pagination": "node scripts/check_pilots_pagination.mjs",
    "check:pilot-directory-sync": "node scripts/check_pilot_directory_sync.mjs",
    "check:session-detail-modes": "node scripts/check_session_detail_modes.mjs",
    "check:session-detail-race-theoretical-buckets": "node scripts/check_session_detail_race_theoretical_buckets.mjs",
    "check:session-pager-merge": "node scripts/check_session_pager_merge.mjs",
    "check:session-electron-reads": "node scripts/check_session_electron_reads.mjs",
    "check:session-list-projection-budget": "node scripts/check_session_list_projection_budget.mjs",
    "check:projection-first": "node scripts/check_projection_first_sources.mjs",
    "check:activity-7d": "node scripts/check_activity_7d_window.mjs",
    "check:owner-rebuild": "node scripts/check_owner_rebuild_contract.mjs",
    "check:owner-maintenance-gate": "node scripts/check_owner_maintenance_gate.mjs",
    "check:summary-only-migration": "node scripts/check_summary_only_migration.mjs",
    "check:no-startup-raw-prefetch": "node scripts/check_no_startup_raw_prefetch.mjs",
    "check:firestore-indexes": "node scripts/check_firestore_indexes.mjs",
    "check:dev-tools-access": "node scripts/check_dev_tools_access.mjs",
    "check:overview-grip-badges": "node scripts/check_overview_grip_badges.mjs",
    "check:coach-calendar": "node scripts/check_coach_calendar_features.mjs",
    "check:pipeline": "powershell -ExecutionPolicy Bypass -File scripts/check_fe_pipeline.ps1",
    "typecheck": "nuxi typecheck",
    "check:typecheck": "npm run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "esbuild": "^0.28.0",
    "firebase": "^12.7.0",
    "kokoro-js": "^1.2.1",
    "nuxt": "4.4.4",
    "vue": "^3.5.26",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "commander": "^13.1.0",
    "eslint-plugin-vue": "^10.9.1",
    "sass": "^1.97.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.128.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4"
  }
}
